{
  "name": "campeonato-futevolei",
  "main": "src/worker.ts",
  "compatibility_date": "2025-06-05",
  // Sem isso, o Wrangler trata "nenhuma variável declarada aqui" como a configuração correta
  // e, a cada deploy, remove qualquer variável/secret que só exista no painel Cloudflare
  // (Settings → Variables and Secrets) e não esteja neste arquivo — foi isso que estava
  // apagando ADMIN_EMAILS (e possivelmente outras) a cada push.
  "keep_vars": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    // Sem isso, a Cloudflare serve "/" e "/index.html" direto da borda (fora do fetch() do
    // Worker) sempre que o caminho bate com um asset estático — foi o que já causava o problema
    // de cache de deploy (ver item 11 do CLAUDE.md). Isso também fazia o roteamento por domínio
    // (www.supremoftv.com.br → institucional.html) nunca rodar: o Worker nunca chegava a
    // executar pra essas duas rotas, então caía sempre no index.html do app. Escopado só nessas
    // duas rotas (em vez de "true" geral) pra não perder o benefício de cache de borda no resto
    // dos assets (ícones, manifest etc.).
    "run_worker_first": ["/", "/index.html"]
  },
  "kv_namespaces": [
    {
      "binding": "DB",
      "id": "e5f15195f2084b19ad39ad13111b5151"
    }
  ],
  // Roda de hora em hora (ver export `scheduled` em src/worker.ts): bloqueia sozinha toda
  // dupla vinda de inscrição pública que ficou "pendente" (sem Pix pago nem aprovação manual)
  // por mais de 24h, liberando a vaga pro próximo interessado — e-mail e log de atividade
  // registram cada expiração.
  "triggers": {
    "crons": ["0 * * * *"]
  }
}
